  create or replace view `onlineretail-491719`.`ecommerce_raw`.`dim_products`
  OPTIONS()
  as WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
),
products AS (
    SELECT
    -------Id
    trim(stock_code) AS stock_code,
    -------Text
    TRIM(description) AS description,
    -------Metrics
    min(price) AS min_price,
    max(price) AS max_price,
    avg(price) AS avg_price,
    count(*) AS nb_transactions,
    count(DISTINCT customer_id) AS nb_customers,
    min(invoice_datetime) AS first_sale_date,
    max(invoice_datetime) AS last_sale_date
    FROM source
    GROUP BY stock_code, description
)
SELECT * FROM products;


[0m19:03:49.415869 [debug] [Thread-3 (]: Opening a new connection, currently in state init
[0m19:03:49.415869 [debug] [Thread-4 (]: On model.OnlineRetail_dbt_Transform.fact_sales: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "OnlineRetail_dbt_Transform", "target_name": "dev", "node_id": "model.OnlineRetail_dbt_Transform.fact_sales"} */


  create or replace view `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
  OPTIONS()
  as WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
)
SELECT
    --surrogate key aka primary key   
    
    ABS(FARM_FINGERPRINT(
    CONCAT(
        COALESCE(CAST(invoice_id AS STRING), ''),
        COALESCE(stock_code, ''),
        COALESCE(CAST(invoice_datetime AS STRING), '')
    )
)) AS transaction_id,

    --business keys
    invoice_id,
    stock_code,
    customer_id,

    --dimensions
    date(invoice_datetime) AS invoice_date,
    country,

    --metrics
    quantity,
    price,
    line_amount,

    --flags métier
    is_return,
    is_cancelled,    
    is_free_item

FROM source;


