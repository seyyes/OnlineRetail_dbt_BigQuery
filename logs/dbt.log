[0m13:42:27.085380 [debug] [Thread-3 (]: On model.OnlineRetail_dbt_Transform.fact_sales: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "OnlineRetail_dbt_Transform", "target_name": "dev", "node_id": "model.OnlineRetail_dbt_Transform.fact_sales"} */


  create or replace view `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
  OPTIONS()
  as WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
)
SELECT
    --surrogate key aka primary key   
    /*
    to_hex(md5(cast(coalesce(cast(invoice_id as string), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(stock_code as string), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(invoice_datetime as string), '_dbt_utils_surrogate_key_null_') as string))) AS transaction_id,*/
    FARM_FINGERPRINT(
        CONCAT(
            CAST(invoice_id AS STRING),
            CAST(stock_code AS STRING),
            CAST(invoice_datetime AS STRING)
        )
    ) AS transaction_id,

    --business keys
    invoice_id,
    stock_code,
    customer_id,

    --dimensions
    date(invoice_datetime) AS invoice_date,
    country,

    --metrics
    quantity,
    price,
    line_amount,

    --flags métier
    is_return,
    is_cancelled,    
    is_free_item

FROM source;


