  create or replace view `onlineretail-491719`.`ecommerce_raw`.`dim_customers`
  OPTIONS()
  as WITH source AS(
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
),
customers AS (
    SELECT 
    customer_id,
    country,

    --activité
    count(distinct invoice_id) AS nb_orders,
    sum(quantity) AS total_quantity,

    --valeur
    sum(line_amount) AS total_revenue,
    avg(line_amount) AS avg_order_value,

    --temporalité
    min(invoice_datetime) AS first_purchase_date,
    max(invoice_datetime) AS last_purchase_date,
    date_diff(current_date(), DATE(max(invoice_datetime)), day) AS recency_days
    FROM source
    GROUP BY customer_id, country
)
SELECT * FROM customers;


