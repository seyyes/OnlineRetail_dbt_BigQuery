  create or replace view `onlineretail-491719`.`ecommerce_raw`.`kpi_global`
  OPTIONS()
  as -- calculer les KPIs globaux à partir de la table fact_sales
WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
),
global_KPIs AS (
    SELECT 
    -- CA total
    sum(line_amount) AS total_revenue,

    -- 
    count(distinct invoice_id) AS total_orders,
    count(distinct customer_id) AS total_customers,
    -- panier moyen global
    sum(line_amount) / nullif(count(distinct invoice_id), 0) as avg_order_value
    FROM source
)
SELECT * FROM global_KPIs;


