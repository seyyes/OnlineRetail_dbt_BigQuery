  create or replace view `onlineretail-491719`.`ecommerce_raw`.`kpi_country`
  OPTIONS()
  as --Analyse métier
WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
),
country_KPIs AS (
    SELECT 
    country, 
    -- CA total
