  create or replace view `onlineretail-491719`.`ecommerce_raw`.`dim_customers`
  OPTIONS()
  as WITH source AS(
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
),
customers AS (
    SELECT 
    customer_id,
    country,

    --activité
    count(distinct invoice_id) AS nb_orders,
    sum(quantity) AS total_quantity,

    --valeur
    sum(line_amount) AS total_revenue,
    avg(line_amount) AS avg_order_value,

    --temporalité
    min(invoice_datetime) AS first_purchase_date,
    max(invoice_datetime) AS last_purchase_date,
    date_diff(current_date(), DATE(max(invoice_datetime)), day) AS recency_days
    FROM source
    GROUP BY customer_id, country
)
SELECT * FROM customers;


[0m10:51:00.413889 [debug] [Thread-2 (]: On model.OnlineRetail_dbt_Transform.fact_sales: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "OnlineRetail_dbt_Transform", "target_name": "dev", "node_id": "model.OnlineRetail_dbt_Transform.fact_sales"} */


  create or replace view `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
  OPTIONS()
  as WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
)
SELECT
    --surrogate key aka primary key   
    
    ABS(FARM_FINGERPRINT(
    CONCAT(
        COALESCE(CAST(invoice_id AS STRING), ''),
        COALESCE(stock_code, ''),
        COALESCE(CAST(invoice_datetime AS STRING), '')
    )
)) AS transaction_id,

    --business keys
    invoice_id,
    stock_code,
    customer_id,

    --dimensions
    date(invoice_datetime) AS invoice_date,
    country,

    --metrics
    quantity,
    price,
    line_amount,

    --flags métier
    is_return,
    is_cancelled,    
    is_free_item

FROM source;


[0m10:51:00.416610 [debug] [Thread-4 (]: On model.OnlineRetail_dbt_Transform.dim_products: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "OnlineRetail_dbt_Transform", "target_name": "dev", "node_id": "model.OnlineRetail_dbt_Transform.dim_products"} */


  create or replace view `onlineretail-491719`.`ecommerce_raw`.`dim_products`
  OPTIONS()
  as WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`stg_online_retail`
),
cleaned_source AS (-- car stockcode + description n'est pas une combinaison unique
    SELECT 
    stock_code,
    description,
    price,
    customer_id,
    invoice_datetime
    FROM source
    WHERE description IS NOT NULL and description != '' --les valeurs nulles créent des doublons sur stockcode et des erreurs en test
),
description_ranked AS (
    SELECT 
    stock_code,
    description,
    count(*) as nb_occurences,
    row_number() OVER(
        PARTITION BY stock_code
        ORDER BY count(*) DESC
    ) as rn 
    FROM cleaned_source
    GROUP BY stock_code, description
),
products AS (
    SELECT
    -------Id
    s.stock_code,
    d.description,
    -------Metrics
    min(price) AS min_price,
    max(price) AS max_price,
    avg(price) AS avg_price,
    count(*) AS nb_transactions,
    count(DISTINCT s.customer_id) AS nb_customers,
    min(s.invoice_datetime) AS first_sale_date,
    max(s.invoice_datetime) AS last_sale_date
    FROM source s 
    LEFT JOIN description_ranked d
    ON s.stock_code = d.stock_code 
    AND d.rn = 1 --garder la description la plus fréquente pour chaque stockcode
    GROUP BY stock_code, description
)
SELECT * FROM products;


