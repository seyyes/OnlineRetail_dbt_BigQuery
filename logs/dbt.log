  create or replace view `onlineretail-491719`.`ecommerce_raw`.`kpi_country`
  OPTIONS()
  as --Analyse métier
WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
),
country_KPIs AS (
    SELECT 
    country, 
    -- CA total
    sum(line_amount) AS total_revenue,
    count(distinct invoice_id) AS total_orders,
    count(distinct customer_id) AS total_customers
    FROM source
    GROUP BY country
)
SELECT * FROM country_KPIs;


