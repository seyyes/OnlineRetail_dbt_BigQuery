  create or replace view `onlineretail-491719`.`ecommerce_raw`.`product_returns`
  OPTIONS()
  as -- Analyse des produits retournés : identifier les produits les plus retournés,le taux de retour
WITH source AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`fact_sales`
), 
products AS (
    SELECT * FROM `onlineretail-491719`.`ecommerce_raw`.`dim_products`
),
products_return AS (
    SELECT 
        s.stock_code,
        p.description,
        count(*) AS nb_sales,
        countif(s.is_return) AS nb_returns,
        countif(s.is_return) / nullif(count(*), 0) * 100 AS return_rate -- Another alternative : sum(CASE WHEN s.is_return THEN 1 ELSE 0 END) AS nb_returns,
    FROM source s
    LEFT JOIN products p ON s.stock_code = p.stock_code
    GROUP BY s.stock_code, p.description
)
SELECT * FROM products_return
ORDER BY return_rate DESC;


