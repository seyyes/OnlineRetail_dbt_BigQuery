  create or replace view `onlineretail-491719`.`ecommerce_raw`.`stg_onlineRetail`
  OPTIONS()
  as -- Staging model for online retail data

-- Uniting the 2 source files
WITH source_2009 AS (
    SELECT  * 
    FROM `onlineretail-491719`.`ecommerce_raw`.`online_retail_2009_2010`
),
source_2010 AS (
    SELECT  * 
    FROM `onlineretail-491719`.`ecommerce_raw`.`online_retail_2010_2011`
),
combined_sources AS(
    SELECT * FROM source_2009
    UNION ALL
    SELECT * FROM source_2010
),
-- cleaning, renaming and formating the data   
cleaned_data AS(
    SELECT 
    --Ids
    CAST(Invoice AS string) AS invoice_id,
    CAST(StockCode AS string) AS stock_code,
    CAST(CustomerID AS string) AS customer_id,

    --Text
    TRIM(Description) AS description,
    TRIM(Country) AS country,

    --Numeric
    SAFE_CAST(Quantity AS int64) AS quantity,
    SAFE_CAST(Price AS float64) AS price,

    --Date
    SAFE_CAST(InvoiceDate AS timestamp) AS invoice_date,

    --Flags métier
    CASE 
    WHEN SAFE_CAST(Quantity AS int64) < 0 THEN TRUE
    ELSE FALSE
    END AS is_returned,

    CASE 
    WHEN CAST(Invoice AS string) LIKE 'C%' THEN TRUE
    ELSE FALSE
    END AS is_canceled,

    CASE 
    WHEN CAST(CustomerID AS string) IS NULL THEN TRUE
    ELSE FALSE
    END AS is_customer_unknown,

    CASE 
    WHEN SAFE_CAST(Price AS float64) = 0 THEN TRUE
    ELSE FALSE
    END AS is_free_item,

    -- Metrics
    SAFE_CAST(Quantity AS int64) * SAFE_CAST(Price AS float64) AS line_Amount
    FROM combined_sources

)
SELECT * FROM cleaned_data;


